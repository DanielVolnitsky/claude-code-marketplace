{
  "$schema": "https://anthropic.com/claude-code/marketplace.schema.json",
  "name": "waytoodanny",
  "description": "Custom Claude Code Marketplace",
  "owner": {
    "name": "Daniel Volnitsky"
  },
  "plugins": [
    {
      "name": "code-review",
      "description": "Code Review activities related skills",
      "source": {
        "source": "git-subdir",
